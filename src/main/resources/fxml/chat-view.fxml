<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aiclient.adapter.input.ui.ChatViewController">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Top: Session Selection -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets bottom="10"/>
            </padding>
            <Label text="Session:"/>
            <ComboBox fx:id="sessionSelector" prefWidth="300" onAction="#handleSessionSelected"/>
            <Button fx:id="newSessionButton" text="New Session" onAction="#handleNewSession"/>
            <Button fx:id="deleteSessionButton" text="Delete Session" onAction="#handleDeleteSession"/>
        </HBox>
    </top>

    <!-- Center: Message List -->
    <center>
        <ListView fx:id="messageList" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="10" bottom="10"/>
            </padding>
        </ListView>
    </center>

    <!-- Bottom: Message Input -->
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10"/>
            </padding>
            <TextField fx:id="messageInput" HBox.hgrow="ALWAYS" promptText="Type your message here..."/>
            <Button fx:id="sendButton" text="Send" onAction="#handleSendMessage" defaultButton="true"/>
        </HBox>
    </bottom>

</BorderPane>
